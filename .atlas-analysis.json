  "keyFeatures": [
    "Fully automatic censorship removal via abliteration",
    "TPE-based parameter optimization with Optuna",
    "Flexible ablation weight kernels across transformer layers",
    "Built-in model evaluation and quality metrics",
    "Quantization support for reduced VRAM usage",
    "Research tools for residual vector analysis",
    "Hugging Face integration for model sharing",
    "Support for dense and MoE architectures"
  ],
  "publicApiSurface": [
    "heretic <model> - Main command to decensor a model",
    "heretic --help - Display all available options",
    "heretic --plot-residuals - Generate residual vector plots",
    "heretic --print-residual-geometry - Print residual geometry analysis",
    "heretic --evaluate-model <model> - Evaluate model performance",
    "heretic --quantization bnb_4bit - Enable 4-bit quantization",
    "heretic --n-trials <n> - Set number of optimization trials",
    "heretic --config <path> - Load configuration from TOML file"
  ]
